{
  "$description": "Norma design tokens — W3C DTCG Format Module v2025.10. The single source of truth for the palette, spacing, type scale, radius and motion. The brand color lives here and nowhere else.",
  "color": {
    "$type": "color",
    "$description": "OKLCH palette. Primitive ramp + semantic aliases (3-tier model).",
    "brand": {
      "azure": { "$value": "oklch(0.58 0.16 252)", "$description": "The one brand hue. Referenced by every azure surface." },
      "azure-ink": { "$value": "oklch(0.45 0.15 258)", "$description": "Darker azure reserved for text/links on light backgrounds (>=4.5:1)." }
    },
    "ink": {
      "1": { "$value": "oklch(0.20 0.028 258)", "$description": "Primary text." },
      "2": { "$value": "oklch(0.40 0.022 258)", "$description": "Secondary text." },
      "3": { "$value": "oklch(0.52 0.018 258)", "$description": "Muted text (AA on paper/surface only)." }
    },
    "paper": { "$value": "oklch(0.983 0.004 250)", "$description": "Page background." },
    "surface": {
      "1": { "$value": "oklch(1 0 0)", "$description": "Card surface." },
      "2": { "$value": "oklch(0.975 0.006 255)", "$description": "Tinted surface." }
    },
    "line": {
      "1": { "$value": "oklch(0.90 0.008 258)" },
      "2": { "$value": "oklch(0.84 0.010 258)" }
    },
    "semantic": {
      "good": { "$value": "oklch(0.66 0.15 155)", "$description": "Positive (decorative fills/dots)." },
      "good-solid": { "$value": "oklch(0.52 0.14 155)", "$description": "Positive fill behind WHITE text (AA >=4.5:1)." },
      "warn": { "$value": "oklch(0.80 0.15 82)" },
      "bad": { "$value": "oklch(0.60 0.20 25)", "$description": "Negative (decorative)." },
      "bad-solid": { "$value": "oklch(0.55 0.19 25)", "$description": "Negative fill behind WHITE text (AA >=4.5:1)." }
    },
    "text": {
      "primary": { "$value": "{color.ink.1}", "$type": "color" },
      "secondary": { "$value": "{color.ink.2}", "$type": "color" },
      "muted": { "$value": "{color.ink.3}", "$type": "color" },
      "link": { "$value": "{color.brand.azure-ink}", "$type": "color" }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "8px grid with a 4px sub-grid. Font sizes do NOT use this scale (see type).",
    "0": { "$value": { "value": 0, "unit": "px" } },
    "1": { "$value": { "value": 4, "unit": "px" } },
    "2": { "$value": { "value": 8, "unit": "px" } },
    "3": { "$value": { "value": 12, "unit": "px" } },
    "4": { "$value": { "value": 16, "unit": "px" } },
    "5": { "$value": { "value": 24, "unit": "px" } },
    "6": { "$value": { "value": 32, "unit": "px" } },
    "7": { "$value": { "value": 48, "unit": "px" } },
    "8": { "$value": { "value": 64, "unit": "px" } },
    "9": { "$value": { "value": 96, "unit": "px" } },
    "10": { "$value": { "value": 128, "unit": "px" } }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Noto Sans", "Be Vietnam Pro", "Arial", "sans-serif"] },
      "mono": { "$value": ["ui-monospace", "SF Mono", "JetBrains Mono", "Menlo", "Consolas", "monospace"] }
    },
    "scale": {
      "$type": "dimension",
      "$description": "Modular scale, base 16px x 1.25 (major third). rem so type respects user zoom.",
      "-1": { "$value": { "value": 0.8, "unit": "rem" } },
      "0": { "$value": { "value": 1, "unit": "rem" }, "$description": "16px body baseline." },
      "1": { "$value": { "value": 1.25, "unit": "rem" } },
      "2": { "$value": { "value": 1.5625, "unit": "rem" } },
      "3": { "$value": { "value": 1.953, "unit": "rem" } },
      "4": { "$value": { "value": 2.441, "unit": "rem" } },
      "5": { "$value": { "value": 3.052, "unit": "rem" } }
    }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": { "value": 6, "unit": "px" } },
    "md": { "$value": { "value": 10, "unit": "px" } }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "$description": "Material 3 duration tokens (verbatim).",
      "short1": { "$value": { "value": 50, "unit": "ms" } },
      "short2": { "$value": { "value": 100, "unit": "ms" } },
      "short3": { "$value": { "value": 150, "unit": "ms" } },
      "short4": { "$value": { "value": 200, "unit": "ms" } },
      "medium2": { "$value": { "value": 300, "unit": "ms" } },
      "long2": { "$value": { "value": 500, "unit": "ms" } }
    },
    "easing": {
      "$type": "cubicBezier",
      "$description": "Material 3 easing tokens (verbatim).",
      "standard": { "$value": [0.2, 0, 0, 1] },
      "standard-decelerate": { "$value": [0, 0, 0, 1] },
      "standard-accelerate": { "$value": [0.3, 0, 1, 1] },
      "emphasized-decelerate": { "$value": [0.05, 0.7, 0.1, 1] },
      "emphasized-accelerate": { "$value": [0.3, 0, 0.8, 0.15] }
    }
  }
}
