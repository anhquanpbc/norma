        "hex": "#1a1c1e"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.537,
          0.929
        ],
        "hex": "#0089ed"
      }
    },
    "tertiary": {
      "$value": {
        "colorSpace": "srgb",
