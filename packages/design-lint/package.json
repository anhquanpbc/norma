{
  "name": "norma-design-lint",
  "version": "1.24.0",
  "mcpName": "io.github.anhquanpbc/norma",
  "description": "Lint HTML/CSS against the Norma web design standard — contrast, focus rings, semantic HTML, labels, reduced-motion, and the common AI-generated design tells.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/anhquanpbc/norma/tree/main/packages/design-lint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anhquanpbc/norma.git",
    "directory": "packages/design-lint"
  },
  "keywords": [
    "design",
    "linter",
    "accessibility",
    "wcag",
    "a11y",
    "design-tokens",
    "ai",
    "css",
    "html",
    "stylelint",
    "eslint"
  ],
  "bin": {
    "norma-design-lint": "dist/cli.js",
    "norma-mcp": "dist/mcp.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./stylelint": {
      "types": "./dist/stylelint.d.ts",
      "default": "./dist/stylelint.js"
    },
    "./eslint": {
      "types": "./dist/eslint.d.ts",
      "default": "./dist/eslint.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README.vi.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node copy-rules.mjs",
    "test": "vitest run --coverage",
    "prepack": "npm run build"
  },
  "dependencies": {
    "culori": "^4.0.1",
    "node-html-parser": "^9.0.0",
    "postcss": "^8.5.19"
  },
  "peerDependencies": {
    "eslint": ">=8.57.0",
    "stylelint": ">=15"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "fast-check": "^4.9.0",
    "postcss-scss": "^4.0.9",
    "stylelint": "^17.14.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
